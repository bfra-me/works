{
  "name": "@bfra.me/create",
  "version": "0.7.14",
  "description": "A command line utility to create new packages from customizable templates.",
  "keywords": [
    "cli",
    "create",
    "template"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bfra-me/works.git",
    "directory": "packages/create"
  },
  "license": "MIT",
  "author": "Marcus R. Brown <contact@bfra.me>",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create": "./dist/cli.js"
  },
  "files": [
    "!**/*.map",
    "dist",
    "src",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "prepack": "pnpm --filter-prod=\"{.}...\" run build",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "clean:test": "rm -rf .tmp test-temp-pm-* test-add-project test-dry-run test/fixtures/temp/*"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.110.0",
    "@bfra.me/es": "workspace:*",
    "@clack/prompts": "1.7.0",
    "cac": "7.0.0",
    "consola": "3.4.2",
    "dotenv": "17.4.2",
    "eta": "4.6.0",
    "giget": "3.3.0",
    "glob": "13.0.6",
    "openai": "6.46.0",
    "package-manager-detector": "1.7.0",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "@bfra.me/works": "workspace:*",
    "happy-dom": "20.10.6",
    "memfs": "4.64.0",
    "msw": "2.15.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
